{
  "doctype": "DocType",
  "name": "Employee Shift",
  "module": "Gravures Custom",
  "custom": 0,
  "issingle": 0,
  "istable": 0,
  "title_field": "employee_name",
  "show_name_in_global_search": 1,
  "image_field": "",
  "autoname": "naming_series:",
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "HR Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ],
  "fields": [
    {
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "options": "ES-.YYYY.-",
      "label": "Naming Series",
      "set_only_once": 1,
      "in_list_view": 0,
      "in_standard_filter": 0
    },
    {
      "fieldname": "employee",
      "fieldtype": "Link",
      "options": "Employee",
      "reqd": 1,
      "label": "Employee",
      "in_list_view": 1,
      "in_standard_filter": 1,
      "in_global_search": 1
    },
    {
      "fieldname": "employee_name",
      "fieldtype": "Read Only",
      "fetch_from": "employee.employee_name",
      "label": "Employee Name",
      "in_list_view": 1,
      "in_standard_filter": 0,
      "in_global_search": 1
    },
    {
      "fieldname": "department",
      "fieldtype": "Read Only",
      "fetch_from": "employee.department",
      "label": "Department",
      "in_list_view": 0,
      "in_standard_filter": 0
    },
    {
      "fieldname": "column_break_main",
      "fieldtype": "Column Break",
      "in_list_view": 0,
      "in_standard_filter": 0
    },
    {
      "fieldname": "shift_date",
      "fieldtype": "Date",
      "reqd": 1,
      "label": "Shift Date (IN date)",
      "description": "Date the shift STARTED (used for month buckets)",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "check_in",
      "fieldtype": "Datetime",
      "label": "Check-In Time",
      "in_list_view": 1,
      "in_standard_filter": 0
    },
    {
      "fieldname": "check_in_record",
      "fieldtype": "Link",
      "options": "Employee Checkin",
      "label": "Check-In Record",
      "in_list_view": 1,
      "columns": 1,
      "in_standard_filter": 0
    },
    {
      "fieldname": "check_out",
      "fieldtype": "Datetime",
      "label": "Check-Out Time",
      "in_list_view": 1,
      "in_standard_filter": 0
    },
    {
      "fieldname": "check_out_record",
      "fieldtype": "Link",
      "options": "Employee Checkin",
      "label": "Check-Out Record",
      "in_list_view": 1,
      "columns": 1,
      "in_standard_filter": 0
    },
    {
      "fieldname": "worked_hours",
      "fieldtype": "Data",
      "read_only": 1,
      "label": "Worked (HH:MM)",
      "in_list_view": 1,
      "in_standard_filter": 0
    },
    {
      "fieldname": "overtime_hours",
      "fieldtype": "Data",
      "read_only": 1,
      "label": "Overtime (HH:MM)",
      "in_list_view": 1,
      "in_standard_filter": 0
    },
    {
      "fieldname": "worked_seconds",
      "fieldtype": "Int",
      "read_only": 1,
      "hidden": 1,
      "label": "Worked Seconds",
      "in_list_view": 0,
      "in_standard_filter": 0
    },
    {
      "fieldname": "overtime_seconds",
      "fieldtype": "Int",
      "read_only": 1,
      "hidden": 1,
      "label": "Overtime Seconds",
      "in_list_view": 0,
      "in_standard_filter": 0
    },
    {
      "fieldname": "standard_hours",
      "fieldtype": "Float",
      "default": "8",
      "label": "Standard Shift Hours",
      "in_list_view": 0,
      "in_standard_filter": 0
    },
    {
      "fieldname": "section_break_checkins",
      "fieldtype": "Section Break",
      "label": "Source Checkins",
      "in_list_view": 0,
      "in_standard_filter": 0
    },
    {
      "fieldname": "column_break_status",
      "fieldtype": "Column Break",
      "in_list_view": 0,
      "in_standard_filter": 0
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "options": "Paired\nMissing Check-Out\nAnomaly\nManual",
      "default": "Paired",
      "reqd": 1,
      "bold": 1,
      "label": "Status",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "anomaly_reason",
      "fieldtype": "Select",
      "options": "\nmissing_checkout\nprevious_month_carryover\nmanual_correction",
      "read_only": 1,
      "label": "Anomaly Reason",
      "in_list_view": 0,
      "in_standard_filter": 0
    },
    {
      "fieldname": "manual_correction",
      "fieldtype": "Check",
      "default": 0,
      "label": "Manual Correction Applied",
      "description": "Checked when user manually edits shift fields",
      "in_list_view": 0,
      "in_standard_filter": 0
    },
    {
      "fieldname": "section_break_lock",
      "fieldtype": "Section Break",
      "label": "Salary Lock",
      "in_list_view": 0,
      "in_standard_filter": 0
    },
    {
      "fieldname": "locked",
      "fieldtype": "Check",
      "default": "0",
      "label": "Locked (by Salary Slip)",
      "read_only": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "lock_period",
      "fieldtype": "Link",
      "options": "Employee Shift Lock",
      "label": "Lock Reference",
      "read_only": 1,
      "in_list_view": 0,
      "in_standard_filter": 0
    }
  ],
  "color": "#29CD41",
  "indicator_color": "green"
}